<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <!-- Include Room Database (AnalyticsDatabase) -->
        <include domain="database" path="usage_database"/>
        <include domain="database" path="usage_database-shm"/>
        <include domain="database" path="usage_database-wal"/>

        <!-- Include DataStore Preferences -->
        <include domain="file" path="datastore"/>
    </cloud-backup>

    <device-transfer>
        <!-- Include Room Database (AnalyticsDatabase) -->
        <include domain="database" path="usage_database"/>
        <include domain="database" path="usage_database-shm"/>
        <include domain="database" path="usage_database-wal"/>

        <!-- Include DataStore Preferences -->
        <include domain="file" path="datastore"/>
    </device-transfer>
</data-extraction-rules>
