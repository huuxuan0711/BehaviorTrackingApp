<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/weekly_overview_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentation.onboarding.splash.SplashActivity">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/loadingContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logo"
            android:alpha="0"
            android:layout_width="@dimen/auto_dp_178"
            android:layout_height="@dimen/auto_dp_178"
            android:scaleX="0.9"
            android:scaleY="0.9"
            android:src="@drawable/digital_wellbeing_logo"/>

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:text="@string/auto_digital_wellbeing"
            android:textSize="@dimen/auto_sp_28"
            android:textColor="@color/weekly_overview_text_primary"
            android:fontFamily="sans-serif-medium"
            android:translationY="@dimen/weekly_trend_icon_container_padding"
            android:layout_marginTop="@dimen/weekly_screen_bottom_padding"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:text="@string/auto_understand_your_digital_habits"
            android:textSize="@dimen/weekly_header_title_size"
            android:textColor="@color/weekly_overview_text_secondary"
            android:fontFamily="sans-serif-light"
            android:translationY="@dimen/weekly_trend_icon_container_padding"
            android:layout_marginTop="@dimen/weekly_small_icon_padding"/>
    </LinearLayout>

    <!-- Loading dots -->
    <LinearLayout
        android:id="@+id/loadingContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/auto_dp_80"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/dot1"
            android:layout_width="@dimen/auto_dp_14"
            android:layout_height="@dimen/auto_dp_14"
            android:layout_margin="@dimen/auto_dp_6"
            android:background="@drawable/bg_dot"/>

        <View
            android:id="@+id/dot2"
            android:layout_width="@dimen/auto_dp_14"
            android:layout_height="@dimen/auto_dp_14"
            android:layout_margin="@dimen/auto_dp_6"
            android:background="@drawable/bg_dot"/>

        <View
            android:id="@+id/dot3"
            android:layout_width="@dimen/auto_dp_14"
            android:layout_height="@dimen/auto_dp_14"
            android:layout_margin="@dimen/auto_dp_6"
            android:background="@drawable/bg_dot"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>


