<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/auto_dp_4">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/auto_dp_4">

        <!-- Background for selected/today state -->
        <View
            android:id="@+id/vwDayBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/weekly_card_elevation"
            android:background="@drawable/bg_calendar_day"
            android:visibility="gone" />

        <!-- Day Button -->
        <Button
            android:id="@+id/btnDay"
            android:layout_width="match_parent"
            android:layout_height="@dimen/weekly_icon_button_size_small"
            android:text="@string/auto_text_1"
            android:textSize="@dimen/auto_sp_14"
            android:textColor="@color/weekly_overview_text_primary"
            android:textStyle="bold"
            android:background="@android:color/transparent"
            android:paddingStart="@dimen/auto_dp_0"
            android:paddingEnd="@dimen/auto_dp_0"
            android:gravity="center"
            android:minHeight="@dimen/weekly_icon_button_size_small"
            android:minWidth="@dimen/weekly_icon_button_size_small"
            android:stateListAnimator="@null" />
    </FrameLayout>

</LinearLayout>



