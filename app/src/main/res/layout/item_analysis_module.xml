<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/weekly_small_icon_padding"
    app:cardCornerRadius="@dimen/weekly_screen_bottom_padding"
    app:cardElevation="@dimen/weekly_card_elevation"
    app:cardBackgroundColor="@color/theme_surface_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/weekly_chart_height"
        android:padding="@dimen/weekly_row_spacing">

        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="@dimen/weekly_icon_button_size"
            android:layout_height="@dimen/weekly_icon_button_size"
            android:background="@drawable/bg_app_icon"
            android:backgroundTint="@color/theme_surface_subtle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgIcon"
                android:layout_width="@dimen/weekly_screen_bottom_padding"
                android:layout_height="@dimen/weekly_screen_bottom_padding"
                android:layout_gravity="center"
                android:src="@drawable/house"
                app:tint="@color/primary" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="@dimen/auto_dp_0"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/weekly_title_spacing_small"
            android:text="@string/auto_usage_patterns"
            android:textColor="@color/weekly_overview_text_primary"
            android:textSize="@dimen/weekly_section_title_size"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iconContainer" />

        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="@dimen/auto_dp_0"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/auto_dp_6"
            android:lineSpacingExtra="@dimen/weekly_card_elevation"
            android:text="@string/auto_explore_patterns_in_your_session_behavior"
            android:textColor="@color/weekly_overview_text_secondary"
            android:textSize="@dimen/auto_sp_14"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <ImageView
            android:id="@+id/imgArrow"
            android:layout_width="@dimen/weekly_screen_bottom_padding"
            android:layout_height="@dimen/weekly_screen_bottom_padding"
            android:layout_marginTop="@dimen/weekly_title_spacing_small"
            android:src="@drawable/chevron_right"
            app:layout_constraintTop_toBottomOf="@id/tvDesc"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:tint="@color/weekly_overview_text_secondary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>



