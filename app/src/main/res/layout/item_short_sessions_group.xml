<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="@dimen/weekly_row_spacing"
    android:paddingTop="@dimen/weekly_trend_icon_container_padding"
    android:paddingEnd="@dimen/weekly_row_spacing"
    android:paddingBottom="@dimen/weekly_trend_icon_container_padding"
    android:layout_marginBottom="@dimen/weekly_title_spacing_small"
    android:background="@drawable/bg_search"
    android:clickable="true"
    android:focusable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tvShortSessionsSummary"
        android:text="@string/auto_other_short_sessions_5_apps"
        android:textColor="@color/weekly_overview_text_secondary"
        android:textSize="@dimen/auto_sp_14"
        android:layout_width="@dimen/auto_dp_0"
        android:layout_height="wrap_content"
        android:layout_weight="1" />

    <ImageView
        android:id="@+id/imgExpand"
        android:src="@drawable/chevron_down"
        android:layout_width="@dimen/weekly_trend_top_spacing"
        android:layout_height="@dimen/weekly_trend_top_spacing" />
</LinearLayout>


