<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/weekly_overview_background"
    tools:context=".presentation.analysis.hub.AnalysisHubFragment">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="@dimen/auto_dp_0"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/weekly_screen_bottom_padding"
        android:paddingEnd="@dimen/weekly_screen_bottom_padding"
        android:paddingTop="@dimen/auto_dp_32"
        android:paddingBottom="@dimen/weekly_row_spacing"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:text="@string/auto_analysis"
            android:textSize="@dimen/auto_sp_26"
            android:textStyle="bold"
            android:textColor="@color/weekly_overview_text_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_marginTop="@dimen/auto_dp_6"
            android:text="@string/auto_start_with_app_categories_then_explore_the_patterns_behind_your_usage"
            android:textSize="@dimen/weekly_body_text_size"
            android:textColor="@color/weekly_overview_text_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvAnalysisStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/weekly_trend_icon_container_padding"
            android:text="@string/auto_insights_work_best_after_categories_match_how_you_personally_use_each_app"
            android:textColor="@color/weekly_overview_text_secondary"
            android:textSize="@dimen/auto_sp_13" />
    </LinearLayout>

    <!-- RecyclerView Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvModules"
        android:layout_width="@dimen/auto_dp_0"
        android:layout_height="@dimen/auto_dp_0"
        android:paddingStart="@dimen/weekly_screen_bottom_padding"
        android:paddingEnd="@dimen/weekly_screen_bottom_padding"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="@dimen/auto_dp_0"
        android:layout_height="@dimen/auto_dp_0"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/theme_surface_glass"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:layout_width="@dimen/auto_dp_36"
            android:layout_height="@dimen/auto_dp_36" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/weekly_trend_icon_container_padding"
            android:text="@string/auto_opening_analysis"
            android:textColor="@color/weekly_overview_text_primary"
            android:textSize="@dimen/auto_sp_14" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>


