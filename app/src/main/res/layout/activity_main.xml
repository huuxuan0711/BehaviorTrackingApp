<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/weekly_overview_background"
    tools:context=".presentation.main.MainActivity">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerMain"
        android:layout_width="@dimen/auto_dp_0"
        android:layout_height="@dimen/auto_dp_0"
        android:background="@color/theme_surface_card"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:itemCount="3" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="@dimen/auto_dp_0"
        android:layout_height="@dimen/auto_dp_80"
        android:paddingBottom="@dimen/weekly_trend_icon_container_padding"
        android:paddingTop="@dimen/weekly_trend_icon_container_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:orientation="horizontal"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:weightSum="3"
        android:elevation="@dimen/auto_dp_6">

        <!-- HOME -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="@dimen/auto_dp_0"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/icon_home"
                android:layout_width="@dimen/weekly_screen_bottom_padding"
                android:layout_height="@dimen/weekly_screen_bottom_padding"
                android:src="@drawable/house"
                app:tint="@color/nav_color_selector" />

            <TextView
                android:id="@+id/text_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/weekly_card_elevation"
                android:text="@string/auto_home"
                android:textSize="@dimen/weekly_body_text_size"
                android:textStyle="bold"
                android:textColor="@color/nav_color_selector"/>
        </LinearLayout>

        <!-- ANALYSIS -->
        <LinearLayout
            android:id="@+id/nav_analysis"
            android:layout_width="@dimen/auto_dp_0"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/icon_analysis"
                android:layout_width="@dimen/weekly_screen_bottom_padding"
                android:layout_height="@dimen/weekly_screen_bottom_padding"
                android:src="@drawable/chart_column"
                app:tint="@color/nav_color_selector" />

            <TextView
                android:id="@+id/text_analysis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/weekly_card_elevation"
                android:text="@string/auto_analysis"
                android:textSize="@dimen/weekly_body_text_size"
                android:textStyle="bold"
                android:textColor="@color/nav_color_selector"/>
        </LinearLayout>

        <!-- SETTINGS -->
        <LinearLayout
            android:id="@+id/nav_settings"
            android:layout_width="@dimen/auto_dp_0"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/icon_settings"
                android:layout_width="@dimen/weekly_screen_bottom_padding"
                android:layout_height="@dimen/weekly_screen_bottom_padding"
                android:src="@drawable/settings"
                app:tint="@color/nav_color_selector" />

            <TextView
                android:id="@+id/text_settings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/weekly_card_elevation"
                android:text="@string/auto_settings"
                android:textSize="@dimen/weekly_body_text_size"
                android:textStyle="bold"
                android:textColor="@color/nav_color_selector"/>
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>



