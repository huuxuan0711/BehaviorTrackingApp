<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/weekly_overview_background"
    tools:context=".presentation.dashboard.session.SessionTimelineActivity">

    <!-- HEADER -->
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/theme_surface_card"
        android:elevation="@dimen/auto_dp_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Top bar -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/weekly_row_spacing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnBack"
                android:src="@drawable/arrow_left"
                android:layout_width="@dimen/auto_dp_28"
                android:layout_height="@dimen/auto_dp_28" />

            <TextView
                android:text="@string/auto_session_timeline"
                android:textSize="@dimen/weekly_header_title_size"
                android:textStyle="bold"
                android:textColor="@color/weekly_overview_text_primary"
                android:layout_marginStart="@dimen/weekly_row_spacing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Date selector -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:padding="@dimen/weekly_title_spacing_small"
            android:layout_margin="@dimen/weekly_row_spacing"
            android:background="@drawable/bg_date_selector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnBackWeek"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="@dimen/weekly_screen_bottom_padding"
                android:layout_height="@dimen/weekly_screen_bottom_padding"
                android:src="@drawable/chevron_left" />

            <TextView
                android:id="@+id/txtDate"
                android:text="@string/auto_wed_mar_11_2026"
                android:textColor="@color/weekly_overview_text_primary"
                android:textStyle="bold"
                android:textSize="@dimen/weekly_section_title_size"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnBackWeek"
                app:layout_constraintEnd_toStartOf="@id/btnNextWeek"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <ImageView
                android:id="@+id/btnNextWeek"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:src="@drawable/chevron_right"
                android:layout_width="@dimen/weekly_screen_bottom_padding"
                android:layout_height="@dimen/weekly_screen_bottom_padding"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <!-- CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentScroll"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="@dimen/auto_dp_0"
        android:layout_weight="1">

        <LinearLayout
            android:orientation="vertical"
            android:padding="@dimen/weekly_row_spacing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <!-- 🔥 INSIGHT (STATIC - KHÔNG nằm trong RecyclerView) -->
        <LinearLayout
            android:orientation="horizontal"
            android:padding="@dimen/weekly_row_spacing"
            android:layout_marginBottom="@dimen/weekly_row_spacing"
            android:background="@drawable/bg_insight_session"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:background="@drawable/bg_circle_amber"
                android:backgroundTint="@color/theme_surface_subtle"
                android:padding="@dimen/weekly_trend_icon_container_padding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="@dimen/auto_dp_22"
                    android:layout_height="@dimen/auto_dp_22"
                    android:src="@drawable/lightbulb"/>
            </LinearLayout>

            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="@dimen/weekly_title_spacing_small"
                android:layout_width="@dimen/auto_dp_0"
                android:layout_weight="1"
                android:layout_height="wrap_content">

                <TextView
                    android:text="@string/auto_insight"
                    android:textStyle="bold"
                    android:textColor="@color/weekly_overview_text_primary"
                    android:textSize="@dimen/weekly_section_title_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvInsight"
                    android:text="@string/auto_you_tend_to_switch_between_social_media_apps_during_late_night_sessions"
                    android:textSize="@dimen/weekly_body_text_size"
                    android:textColor="@color/weekly_overview_text_secondary"
                    android:layout_marginTop="@dimen/auto_dp_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>

        <!-- 🔥 RECYCLER VIEW (Morning → Late Night) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtEmptySessions"
            android:visibility="gone"
            android:text="@string/auto_no_meaningful_sessions_for_this_day_yet_try_another_day_or_check_back_after_using_your_phone"
            android:textColor="@color/weekly_overview_text_secondary"
            android:textSize="@dimen/auto_sp_14"
            android:gravity="center"
            android:padding="@dimen/weekly_row_spacing"
            android:background="@drawable/bg_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>



