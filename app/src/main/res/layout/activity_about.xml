<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/weekly_overview_background"
    tools:context=".presentation.settings.about.AboutActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/weekly_screen_bottom_padding">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="@dimen/weekly_icon_button_size"
            android:paddingBottom="@dimen/auto_dp_32">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_gravity="start"
                android:layout_marginStart="@dimen/_20sdp"
                android:layout_width="@dimen/auto_dp_30"
                android:layout_height="@dimen/auto_dp_30"
                android:src="@drawable/arrow_left"/>

            <FrameLayout
                android:layout_width="@dimen/auto_dp_80"
                android:layout_height="@dimen/auto_dp_80"
                android:backgroundTint="@color/primary"
                android:background="@drawable/bg_app_icon"
                android:padding="@dimen/weekly_row_spacing"
                android:layout_marginBottom="@dimen/weekly_row_spacing"
                android:clipToOutline="true">

                <!-- Icon -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/smartphone"
                    android:tint="@android:color/white"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_digital_wellbeing_assistant"
                android:textColor="@color/weekly_overview_text_primary"
                android:textSize="@dimen/weekly_header_title_size"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingHorizontal="@dimen/weekly_screen_bottom_padding"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_understand_your_digital_habits_and_build_healthier_phone_usage_patterns"
                android:textColor="@color/weekly_overview_text_secondary"
                android:textSize="@dimen/auto_sp_14"
                android:gravity="center"
                android:paddingHorizontal="@dimen/auto_dp_32"
                android:layout_marginTop="@dimen/weekly_trend_icon_container_padding"/>
        </LinearLayout>

        <!-- Version Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/weekly_trend_top_spacing"
            android:layout_marginBottom="@dimen/weekly_row_spacing"
            app:cardElevation="@dimen/weekly_card_elevation">

            <LinearLayout
                android:background="@drawable/bg_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/weekly_row_spacing">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/weekly_small_icon_padding"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="@dimen/auto_dp_0"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="@dimen/weekly_body_text_size"
                        android:text="@string/auto_version"
                        android:textColor="@color/weekly_overview_text_primary"/>

                    <TextView
                        android:id="@+id/txtVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/weekly_body_text_size"
                        android:text="@string/auto_text_1_2_4"
                        android:textColor="@color/weekly_overview_text_secondary"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/weekly_trend_icon_container_padding"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="@dimen/auto_dp_0"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="@dimen/weekly_body_text_size"
                        android:text="@string/auto_last_updated"
                        android:textColor="@color/weekly_overview_text_primary"/>

                    <TextView
                        android:id="@+id/txtLastUpdate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/weekly_body_text_size"
                        android:text="@string/auto_march_10_2026"
                        android:textColor="@color/weekly_overview_text_secondary"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Mission Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/weekly_trend_top_spacing"
            android:layout_marginBottom="@dimen/weekly_row_spacing"
            app:cardElevation="@dimen/weekly_card_elevation">

            <LinearLayout
                android:padding="@dimen/weekly_row_spacing"
                android:background="@drawable/bg_search"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_our_mission"
                    android:textSize="@dimen/weekly_section_title_size"
                    android:textColor="@color/weekly_overview_text_primary"
                    android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/auto_sp_14"
                    android:text="@string/auto_our_goal_is_to_help_users_understand_their_digital_behavior_and_make_mindful_decisions_about_phone_usage"
                    android:textColor="@color/weekly_overview_text_secondary"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Links Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/weekly_trend_top_spacing"
            android:layout_marginBottom="@dimen/weekly_row_spacing">

            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Item -->
                <LinearLayout
                    android:id="@+id/item_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/weekly_row_spacing"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/auto_dp_18"
                        android:layout_height="@dimen/auto_dp_18"
                        android:tint="@color/primary"
                        android:src="@drawable/shield"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/weekly_title_spacing_small"
                        android:layout_weight="1"
                        android:textStyle="bold"
                        android:textSize="@dimen/auto_sp_14"
                        android:text="@string/auto_privacy_policy"
                        android:textColor="@color/weekly_overview_text_primary"/>

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/chevron_right"/>
                </LinearLayout>

                <!-- divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/auto_dp_1"
                    android:background="@color/auto_color_eeeeee"/>

                <!-- Terms -->
                <LinearLayout
                    android:id="@+id/item_terms"
                    android:padding="@dimen/weekly_row_spacing"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/auto_dp_18"
                        android:layout_height="@dimen/auto_dp_18"
                        android:tint="@color/primary"
                        android:src="@drawable/file_text"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/weekly_title_spacing_small"
                        android:layout_weight="1"
                        android:textSize="@dimen/auto_sp_14"
                        android:textStyle="bold"
                        android:text="@string/auto_terms_of_service"
                        android:textColor="@color/weekly_overview_text_primary"/>

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/chevron_right"/>
                </LinearLayout>

                <!-- divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/auto_dp_1"
                    android:background="@color/auto_color_eeeeee"/>

                <!-- Terms -->
                <LinearLayout
                    android:id="@+id/item_opensource"
                    android:padding="@dimen/weekly_row_spacing"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/auto_dp_18"
                        android:layout_height="@dimen/auto_dp_18"
                        android:tint="@color/primary"
                        android:src="@drawable/book"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/weekly_title_spacing_small"
                        android:layout_weight="1"
                        android:textStyle="bold"
                        android:textSize="@dimen/auto_sp_14"
                        android:text="@string/auto_open_source_licenses"
                        android:textColor="@color/weekly_overview_text_primary"/>

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/chevron_right"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Support Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/weekly_trend_top_spacing"
            app:cardCornerRadius="@dimen/weekly_row_spacing">

            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/item_contact"
                    android:padding="@dimen/weekly_row_spacing"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/auto_dp_18"
                        android:layout_height="@dimen/auto_dp_18"
                        android:tint="@color/primary"
                        android:src="@drawable/mail"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/weekly_title_spacing_small"
                        android:layout_weight="1"
                        android:textStyle="bold"
                        android:textSize="@dimen/auto_sp_14"
                        android:text="@string/auto_contact_support"
                        android:textColor="@color/weekly_overview_text_primary"/>

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/chevron_right"/>
                </LinearLayout>

                <!-- divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/auto_dp_1"
                    android:background="@color/auto_color_eeeeee"/>

                <!-- Terms -->
                <LinearLayout
                    android:id="@+id/item_send_feedback"
                    android:padding="@dimen/weekly_row_spacing"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/auto_dp_18"
                        android:layout_height="@dimen/auto_dp_18"
                        android:tint="@color/primary"
                        android:src="@drawable/message_square"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/weekly_title_spacing_small"
                        android:layout_weight="1"
                        android:textSize="@dimen/auto_sp_14"
                        android:textStyle="bold"
                        android:text="@string/auto_send_feedback"
                        android:textColor="@color/weekly_overview_text_primary"/>

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/chevron_right"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>


