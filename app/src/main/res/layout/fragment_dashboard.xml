<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/refreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentation.dashboard.home.DashboardFragment">

<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/weekly_overview_background">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="@dimen/auto_dp_0"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/weekly_trend_top_spacing"
        android:paddingEnd="@dimen/weekly_trend_top_spacing"
        android:paddingTop="@dimen/weekly_screen_bottom_padding"
        android:paddingBottom="@dimen/weekly_title_spacing_small"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_friday_march_13"
            android:textSize="@dimen/weekly_section_title_size"
            android:textColor="@color/weekly_overview_text_secondary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/weekly_trend_icon_container_padding"
            android:text="@string/auto_today"
            android:textSize="@dimen/auto_sp_24"
            android:textStyle="bold"
            android:textColor="@color/weekly_overview_text_primary"/>
    </LinearLayout>

    <!-- SCROLL CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="@dimen/auto_dp_0"
        android:paddingStart="@dimen/weekly_trend_top_spacing"
        android:paddingEnd="@dimen/weekly_trend_top_spacing"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:paddingBottom="@dimen/weekly_trend_top_spacing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Insight Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardKeyInsight"
                android:layout_marginTop="@dimen/weekly_trend_icon_container_padding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:padding="@dimen/weekly_trend_top_spacing"
                android:layout_marginBottom="@dimen/weekly_row_spacing"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/imgInsight"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:src="@drawable/moon"
                    android:layout_width="@dimen/auto_dp_22"
                    android:layout_height="@dimen/auto_dp_22"
                    app:tint="@color/primary" />

                <TextView
                    android:id="@+id/txt1"
                    app:layout_constraintStart_toEndOf="@id/imgInsight"
                    app:layout_constraintTop_toTopOf="@id/imgInsight"
                    app:layout_constraintBottom_toBottomOf="@id/imgInsight"
                    android:textSize="@dimen/weekly_section_title_size"
                    android:text="@string/auto_key_insight"
                    android:textColor="@color/theme_accent_primary"
                    android:layout_marginStart="@dimen/weekly_trend_top_spacing"
                    android:layout_marginTop="@dimen/auto_dp_neg_10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtKeyInsight"
                    app:layout_constraintTop_toBottomOf="@id/txt1"
                    app:layout_constraintStart_toStartOf="@id/txt1"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_width="@dimen/auto_dp_0"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/weekly_trend_icon_container_padding"
                    android:text="@string/auto_you_tend_to_use_social_media_more_frequently_after_11_pm"
                    android:textColor="@color/weekly_overview_text_primary"
                    android:textSize="@dimen/weekly_body_text_size"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Quick Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/weekly_row_spacing">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_quick_stats"
                    android:textStyle="bold"
                    android:textSize="@dimen/weekly_section_title_size"
                    android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false">

                    <androidx.cardview.widget.CardView
                        app:cardCornerRadius="@dimen/weekly_trend_icon_container_padding"
                        android:layout_width="@dimen/auto_dp_0"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/weekly_small_icon_padding"
                        android:layout_weight="1">

                        <LinearLayout
                            android:paddingTop="@dimen/weekly_title_spacing_small"
                            android:paddingBottom="@dimen/weekly_trend_top_spacing"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="@dimen/auto_dp_22"
                                android:layout_height="@dimen/auto_dp_22"
                                android:src="@drawable/smartphone"
                                android:layout_marginBottom="@dimen/auto_dp_6"
                                app:tint="@color/primary" />

                            <TextView
                                android:gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:id="@+id/valueScreenTime"
                                android:text="@string/auto_text_5h_42m"
                                android:textSize="@dimen/weekly_section_title_size"
                                android:textColor="@color/weekly_overview_text_primary"/>

                            <TextView
                                android:gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/auto_dp_4"
                                android:text="@string/auto_screen_time"
                                android:textColor="@color/weekly_overview_text_secondary"
                                android:textSize="@dimen/auto_sp_12"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="@dimen/auto_dp_0"
                        app:cardCornerRadius="@dimen/weekly_trend_icon_container_padding"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/auto_dp_4"
                        android:layout_weight="1">

                        <LinearLayout
                            android:paddingTop="@dimen/weekly_title_spacing_small"
                            android:paddingBottom="@dimen/auto_dp_6"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="@dimen/auto_dp_22"
                                android:layout_height="@dimen/auto_dp_22"
                                android:layout_marginBottom="@dimen/auto_dp_6"
                                android:src="@drawable/clock"
                                app:tint="@color/primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:id="@+id/valueLongestSession"
                                android:gravity="center"
                                android:textSize="@dimen/weekly_section_title_size"
                                android:text="@string/auto_text_42m"
                                android:textColor="@color/weekly_overview_text_primary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:layout_marginTop="@dimen/auto_dp_4"
                                android:text="@string/auto_longest_nsession"
                                android:textColor="@color/weekly_overview_text_secondary"
                                android:textSize="@dimen/auto_sp_12"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="@dimen/auto_dp_0"
                        app:cardCornerRadius="@dimen/weekly_trend_icon_container_padding"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/weekly_small_icon_padding"
                        android:layout_weight="1">

                        <LinearLayout
                            android:paddingTop="@dimen/weekly_title_spacing_small"
                            android:paddingBottom="@dimen/weekly_trend_top_spacing"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="@dimen/auto_dp_22"
                                android:layout_height="@dimen/auto_dp_22"
                                android:layout_marginBottom="@dimen/auto_dp_6"
                                android:src="@drawable/moon"
                                app:tint="@color/primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:id="@+id/valueLateNight"
                                android:layout_gravity="center"
                                android:text="@string/auto_text_32"
                                android:textSize="@dimen/weekly_section_title_size"
                                android:textColor="@color/weekly_overview_text_primary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/auto_dp_4"
                                android:gravity="center"
                                android:text="@string/auto_late_night"
                                android:textColor="@color/weekly_overview_text_secondary"
                                android:textSize="@dimen/auto_sp_12"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/weekly_section_spacing"
                app:cardCornerRadius="@dimen/weekly_card_corner_radius"
                app:cardElevation="@dimen/weekly_card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/weekly_card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_usage_distribution"
                        android:textStyle="bold"
                        android:textSize="@dimen/weekly_section_title_size"
                        android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"/>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/auto_dp_200">

                        <!-- Chart -->
                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>

                        <TextView
                            android:id="@+id/txtEmptyChart"
                            android:visibility="gone"
                            android:gravity="center"
                            android:text="@string/auto_no_hourly_activity_yet_pull_to_refresh_after_using_your_phone"
                            android:textColor="@color/weekly_overview_text_secondary"
                            android:textSize="@dimen/auto_sp_14"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>
                    </FrameLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Top Apps -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/weekly_row_spacing">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_top_apps"
                    android:textSize="@dimen/weekly_section_title_size"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewTopApps"
                    android:clipToPadding="false"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtEmptyTopApps"
                    android:visibility="gone"
                    android:text="@string/auto_no_top_apps_yet_pull_to_refresh_once_usage_data_is_available"
                    android:textColor="@color/weekly_overview_text_secondary"
                    android:textSize="@dimen/auto_sp_14"
                    android:padding="@dimen/weekly_row_spacing"
                    android:background="@drawable/bg_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Shortcuts -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_quick_access"
                    android:textStyle="bold"
                    android:textSize="@dimen/weekly_section_title_size"
                    android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardDailyOverview"
                        android:layout_weight="1"
                        android:layout_width="@dimen/auto_dp_0"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/weekly_small_icon_padding"
                        app:cardCornerRadius="@dimen/weekly_trend_icon_container_padding"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:paddingTop="@dimen/weekly_row_spacing"
                            android:paddingBottom="@dimen/weekly_row_spacing"
                            android:paddingStart="@dimen/auto_dp_22"
                            android:paddingEnd="@dimen/auto_dp_22"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:src="@drawable/calendar"
                                android:layout_width="@dimen/auto_dp_22"
                                android:layout_height="@dimen/auto_dp_22"
                                app:tint="@color/primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/weekly_small_icon_padding"
                                android:maxWidth="80dp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:gravity="center"
                                android:text="@string/auto_daily"
                                android:textStyle="bold"
                                android:textColor="@color/weekly_overview_text_primary"
                                android:textSize="@dimen/auto_sp_14"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardWeeklyOverview"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="@dimen/auto_dp_4"
                        android:layout_width="@dimen/auto_dp_0"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="@dimen/weekly_trend_icon_container_padding"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:padding="@dimen/weekly_row_spacing"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:src="@drawable/trending_up"
                                android:layout_width="@dimen/auto_dp_22"
                                android:layout_height="@dimen/auto_dp_22"
                                app:tint="@color/primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/weekly_small_icon_padding"
                                android:maxWidth="80dp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:gravity="center"
                                android:text="@string/auto_weekly"
                                android:textStyle="bold"
                                android:textColor="@color/weekly_overview_text_primary"
                                android:textSize="@dimen/auto_sp_14" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardSessionTimeline"
                        android:layout_weight="1"
                        android:layout_width="@dimen/auto_dp_0"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/weekly_small_icon_padding"
                        app:cardCornerRadius="@dimen/weekly_trend_icon_container_padding"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:padding="@dimen/weekly_row_spacing"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:src="@drawable/chart_column"
                                android:layout_width="@dimen/auto_dp_22"
                                android:layout_height="@dimen/auto_dp_22"
                                app:tint="@color/primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/weekly_small_icon_padding"
                                android:maxWidth="100dp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:gravity="center"
                                android:text="@string/auto_timeline"
                                android:textStyle="bold"
                                android:textColor="@color/weekly_overview_text_primary"
                                android:textSize="@dimen/auto_sp_14"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>


