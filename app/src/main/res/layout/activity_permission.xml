<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/weekly_overview_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentation.onboarding.permission.PermissionActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="@dimen/auto_dp_0"
        android:layout_height="@dimen/auto_dp_0"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="@dimen/weekly_row_spacing"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ================= TOP: Illustration ================= -->
            <ImageView
                android:id="@+id/imgIllustration"
                android:layout_width="@dimen/auto_dp_198"
                android:layout_height="@dimen/auto_dp_198"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/weekly_icon_button_size_small"
                android:layout_marginBottom="@dimen/weekly_row_spacing"
                android:contentDescription="@string/auto_usage_illustration"
                android:src="@drawable/ic_usage_access" />

            <!-- ================= CENTER: Content Card ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/weekly_screen_bottom_padding"
                android:layout_marginBottom="@dimen/weekly_row_spacing"
                android:backgroundTint="@color/white"
                app:cardCornerRadius="@dimen/weekly_screen_bottom_padding"
                app:cardElevation="@dimen/weekly_card_elevation"
                app:strokeWidth="@dimen/auto_dp_0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/auto_dp_30">

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/weekly_trend_top_spacing"
                        android:text="@string/auto_allow_usage_access"
                        android:textColor="@color/weekly_overview_text_primary"
                        android:textSize="@dimen/weekly_header_title_size"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/weekly_trend_top_spacing"
                        android:lineSpacingExtra="@dimen/auto_dp_4"
                        android:text="@string/auto_to_understand_your_digital_habits_the_app_needs_permission_to_view_app_usage_statistics_this_allows_us_to_analyze_usage_sessions_and_provide_meaningful_insights"
                        android:textColor="@color/weekly_overview_text_secondary"
                        android:textSize="@dimen/weekly_section_title_size" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/auto_dp_18"
                            android:layout_height="@dimen/auto_dp_18"
                            android:layout_marginTop="@dimen/auto_dp_4"
                            android:layout_marginEnd="@dimen/weekly_small_icon_padding"
                            android:alpha="0.6"
                            android:src="@drawable/ic_info"
                            app:tint="@color/primary" />

                        <TextView
                            android:id="@+id/tvNote"
                            android:layout_width="@dimen/auto_dp_0"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/auto_we_never_access_personal_content_or_messages"
                            android:textColor="@color/weekly_overview_text_secondary"
                            android:textSize="@dimen/weekly_body_text_size" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ================= BOTTOM: Buttons ================= -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="@dimen/auto_dp_0"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="@dimen/weekly_screen_bottom_padding"
        android:layout_marginBottom="@dimen/weekly_screen_bottom_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Primary Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenSettings"
            android:layout_width="match_parent"
            android:layout_height="@dimen/auto_dp_66"
            android:text="@string/auto_open_settings"
            android:textSize="@dimen/weekly_section_title_size"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:layout_marginBottom="@dimen/weekly_title_spacing_small"
            app:cornerRadius="@dimen/auto_dp_28"
            android:backgroundTint="@color/primary"/>

        <!-- Secondary Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMaybeLater"
            android:layout_width="match_parent"
            android:layout_height="@dimen/weekly_selector_min_height"
            android:text="@string/auto_maybe_later"
            android:textSize="@dimen/weekly_section_title_size"
            android:textAllCaps="false"
            android:textColor="@color/weekly_overview_text_secondary"
            app:cornerRadius="@dimen/auto_dp_28"
            android:backgroundTint="@android:color/transparent"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>


