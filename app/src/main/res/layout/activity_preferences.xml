<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/weekly_overview_background"
    tools:context=".presentation.settings.preferences.PreferencesActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/weekly_row_spacing">

        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="@dimen/_20sdp"
            android:layout_marginBottom="@dimen/_20sdp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/auto_dp_30"
                android:layout_height="@dimen/auto_dp_30"
                android:src="@drawable/arrow_left"/>

            <!-- HEADER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_preferences"
                android:textSize="@dimen/auto_sp_26"
                android:textStyle="bold"
                android:layout_marginStart="@dimen/_10sdp"
                android:textColor="@color/weekly_overview_text_primary"/>
        </LinearLayout>

        <!-- ================= ANALYSIS SETTINGS ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_search"
            android:elevation="@dimen/weekly_card_elevation"
            android:layout_marginBottom="@dimen/weekly_row_spacing">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_analysis_settings"
                android:textColor="@color/weekly_overview_text_primary"
                android:textSize="@dimen/weekly_header_title_size"
                android:textStyle="bold"
                android:padding="@dimen/weekly_row_spacing"/>

            <!-- Late Night Threshold -->
            <LinearLayout
                android:padding="@dimen/weekly_row_spacing"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:src="@drawable/clock"
                    android:layout_marginEnd="@dimen/weekly_row_spacing"
                    android:layout_width="@dimen/weekly_screen_bottom_padding"
                    android:layout_height="@dimen/weekly_screen_bottom_padding"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"
                        android:text="@string/auto_late_night_threshold"
                        android:textSize="@dimen/weekly_section_title_size"
                        android:textColor="@color/weekly_overview_text_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_define_when_app_usage_is_considered_late_night"
                        android:textSize="@dimen/weekly_body_text_size"
                        android:textColor="@color/weekly_overview_text_secondary"
                        android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"/>

                    <SeekBar
                        android:layout_height="@dimen/weekly_trend_top_spacing"
                        android:id="@+id/seekLateNight"
                        android:layout_width="match_parent"
                        android:max="5"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/auto_dp_4">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/auto_text_8_00_pm"
                            android:textSize="@dimen/auto_sp_14"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvLateNightValue"
                            android:textStyle="bold"
                            android:textSize="@dimen/weekly_body_text_size"
                            android:text="@string/auto_text_10_00_pm"
                            android:textColor="@color/primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="@string/auto_text_1_00_am"
                            android:textSize="@dimen/auto_sp_14"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Session Length -->
            <LinearLayout
                android:padding="@dimen/weekly_row_spacing"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:src="@drawable/smartphone"
                    android:layout_marginEnd="@dimen/weekly_row_spacing"
                    android:layout_width="@dimen/weekly_screen_bottom_padding"
                    android:layout_height="@dimen/weekly_screen_bottom_padding"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_session_length_threshold"
                        android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"
                        android:textSize="@dimen/weekly_section_title_size"
                        android:textColor="@color/weekly_overview_text_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_set_when_a_session_is_considered_long"
                        android:textSize="@dimen/weekly_body_text_size"
                        android:textColor="@color/weekly_overview_text_secondary"
                        android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"/>

                    <SeekBar
                        android:layout_height="wrap_content"
                        android:id="@+id/seekSession"
                        android:layout_width="match_parent"
                        android:max="4"/>

                    <LinearLayout
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/auto_dp_4">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/auto_text_10_min"
                            android:textSize="@dimen/auto_sp_14"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvSessionValue"
                            android:textStyle="bold"
                            android:textSize="@dimen/weekly_body_text_size"
                            android:text="@string/auto_text_20_minutes"
                            android:textColor="@color/primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="@string/auto_text_30_min"
                            android:textSize="@dimen/auto_sp_14"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- App Category Tracking -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/weekly_row_spacing"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:src="@drawable/trending_up"
                    app:tint="@color/primary"
                    android:layout_gravity="top"
                    android:layout_marginEnd="@dimen/weekly_row_spacing"
                    android:layout_width="@dimen/weekly_screen_bottom_padding"
                    android:layout_height="@dimen/weekly_screen_bottom_padding"/>

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="@dimen/auto_dp_0"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_app_category_tracking"
                        android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"
                        android:textSize="@dimen/weekly_section_title_size"
                        android:textColor="@color/weekly_overview_text_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_include_all_app_categories_in_analysis"
                        android:textSize="@dimen/weekly_body_text_size"
                        android:textColor="@color/weekly_overview_text_secondary"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/auto_dp_6"
                    app:track="@drawable/switch_track"
                    app:thumbTint="@color/white"
                    app:trackTint="@null"
                    android:showText="false"
                    app:switchMinWidth="@dimen/auto_dp_44"
                    app:switchPadding="@dimen/auto_dp_0"
                    android:minHeight="@dimen/weekly_screen_bottom_padding"
                    android:minWidth="@dimen/auto_dp_44" />
            </LinearLayout>
        </LinearLayout>

        <!-- ================= DISPLAY SETTINGS ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_search"
            android:elevation="@dimen/weekly_card_elevation"
            android:layout_marginBottom="@dimen/weekly_row_spacing">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_display_settings"
                android:textColor="@color/weekly_overview_text_primary"
                android:textSize="@dimen/weekly_header_title_size"
                android:textStyle="bold"
                android:padding="@dimen/weekly_row_spacing"/>

            <!-- Insight Notifications -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/weekly_row_spacing"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:src="@drawable/bell"
                    app:tint="@color/primary"
                    android:layout_gravity="top"
                    android:layout_marginEnd="@dimen/weekly_row_spacing"
                    android:layout_width="@dimen/weekly_screen_bottom_padding"
                    android:layout_height="@dimen/weekly_screen_bottom_padding"/>

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="@dimen/auto_dp_0"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_insight_notifications"
                        android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"
                        android:textSize="@dimen/weekly_section_title_size"
                        android:textColor="@color/weekly_overview_text_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_get_notified_about_behavior_patterns"
                        android:textSize="@dimen/weekly_body_text_size"
                        android:textColor="@color/weekly_overview_text_secondary"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchInsight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/auto_dp_6"
                    app:track="@drawable/switch_track"
                    app:thumbTint="@color/white"
                    app:trackTint="@null"
                    android:showText="false"
                    app:switchMinWidth="@dimen/auto_dp_44"
                    app:switchPadding="@dimen/auto_dp_0"
                    android:minHeight="@dimen/weekly_screen_bottom_padding"
                    android:minWidth="@dimen/auto_dp_44" />
            </LinearLayout>

            <!-- Dark Mode -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/weekly_row_spacing"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:src="@drawable/moon"
                    app:tint="@color/primary"
                    android:layout_gravity="top"
                    android:layout_marginEnd="@dimen/weekly_row_spacing"
                    android:layout_width="@dimen/weekly_screen_bottom_padding"
                    android:layout_height="@dimen/weekly_screen_bottom_padding"/>

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="@dimen/auto_dp_0"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_dark_mode"
                        android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"
                        android:textSize="@dimen/weekly_section_title_size"
                        android:textColor="@color/weekly_overview_text_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_use_dark_theme_throughout_the_app"
                        android:textSize="@dimen/weekly_body_text_size"
                        android:textColor="@color/weekly_overview_text_secondary"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDarkMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/auto_dp_6"
                    app:track="@drawable/switch_track"
                    app:thumbTint="@color/white"
                    app:trackTint="@null"
                    android:showText="false"
                    app:switchMinWidth="@dimen/auto_dp_44"
                    app:switchPadding="@dimen/auto_dp_0"
                    android:minHeight="@dimen/weekly_screen_bottom_padding"
                    android:minWidth="@dimen/auto_dp_44" />
            </LinearLayout>

            <!-- Weekly Reports -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/weekly_row_spacing"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:src="@drawable/file_text"
                    app:tint="@color/primary"
                    android:layout_gravity="top"
                    android:layout_marginEnd="@dimen/weekly_row_spacing"
                    android:layout_width="@dimen/weekly_screen_bottom_padding"
                    android:layout_height="@dimen/weekly_screen_bottom_padding"/>

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="@dimen/auto_dp_0"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_weekly_reports"
                        android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"
                        android:textSize="@dimen/weekly_section_title_size"
                        android:textColor="@color/weekly_overview_text_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_receive_weekly_usage_summaries"
                        android:textSize="@dimen/weekly_body_text_size"
                        android:textColor="@color/weekly_overview_text_secondary"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchWeekly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/auto_dp_6"
                    app:track="@drawable/switch_track"
                    app:thumbTint="@color/white"
                    app:trackTint="@null"
                    android:showText="false"
                    app:switchMinWidth="@dimen/auto_dp_44"
                    app:switchPadding="@dimen/auto_dp_0"
                    android:minHeight="@dimen/weekly_screen_bottom_padding"
                    android:minWidth="@dimen/auto_dp_44" />
            </LinearLayout>

            <!-- App Language -->
            <LinearLayout
                android:id="@+id/layoutLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/weekly_row_spacing"
                android:orientation="horizontal"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical">

                <ImageView
                    android:src="@drawable/languages"
                    app:tint="@color/primary"
                    android:layout_gravity="top"
                    android:layout_marginEnd="@dimen/weekly_row_spacing"
                    android:layout_width="@dimen/weekly_screen_bottom_padding"
                    android:layout_height="@dimen/weekly_screen_bottom_padding"/>

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="@dimen/auto_dp_0"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_app_language"
                        android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"
                        android:textSize="@dimen/weekly_section_title_size"
                        android:textColor="@color/weekly_overview_text_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvCurrentLanguage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_language_english"
                        android:textSize="@dimen/weekly_body_text_size"
                        android:textColor="@color/weekly_overview_text_secondary"/>
                </LinearLayout>

                <ImageView
                    android:src="@drawable/chevron_right"
                    android:layout_marginEnd="@dimen/weekly_trend_icon_container_padding"
                    android:layout_width="@dimen/auto_dp_28"
                    android:layout_height="@dimen/auto_dp_28"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ================= SENSITIVITY ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_search"
            android:elevation="@dimen/weekly_card_elevation"
            android:padding="@dimen/weekly_row_spacing">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_insight_sensitivity"
                android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"
                android:textSize="@dimen/weekly_section_title_size"
                android:textColor="@color/weekly_overview_text_primary"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_control_how_sensitive_pattern_detection_is"
                android:textSize="@dimen/weekly_body_text_size"
                android:textColor="@color/weekly_overview_text_secondary"
                android:layout_marginBottom="@dimen/weekly_trend_icon_container_padding"/>

            <SeekBar
                android:layout_height="wrap_content"
                android:id="@+id/seekSensitivity"
                android:layout_width="match_parent"
                android:max="2"/>

            <LinearLayout
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/weekly_small_icon_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_low"
                    android:textSize="@dimen/auto_sp_14"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvSensitivityValue"
                    android:textStyle="bold"
                    android:textSize="@dimen/weekly_body_text_size"
                    android:text="@string/auto_medium"
                    android:textColor="@color/primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="@string/auto_high"
                    android:textSize="@dimen/auto_sp_14"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>


