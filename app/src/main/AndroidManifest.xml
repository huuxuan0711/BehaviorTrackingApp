<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".Project2DigitalWellbeingApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Project2DigitalWellbeing">
        <activity
            android:name=".presentation.settings.about.AboutActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.settings.preferences.PreferencesActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.settings.privacy.PrivacyAndDataActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.analysis.behavior.BehaviorInsightDetailActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.analysis.usagepattern.UsagePatternDetailActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.analysis.latenight.LateNightAnalysisActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.analysis.transition.AppTransitionGraphActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.analysis.appcategory.AppCategoryActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.dashboard.session.SessionTimelineActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.dashboard.weekly.WeeklyOverviewActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.dashboard.daily.DailyOverviewActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.onboarding.permission.PermissionActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.onboarding.intro.IntroActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.onboarding.splash.SplashActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".presentation.main.MainActivity"
            android:exported="true">

        </activity>
    </application>

</manifest>
